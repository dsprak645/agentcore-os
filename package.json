{
  "name": "agentcore-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next-dev',{recursive:true,force:true});\" && next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "stable": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});\" && next build && next start -p 3000",
    "lint": "next lint",
    "webhook:dev": "node scripts/webhook-connector/server.mjs",
    "publish-queue:worker": "node scripts/publish-queue-worker.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "15.1.6",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "license": "Apache-2.0"
}

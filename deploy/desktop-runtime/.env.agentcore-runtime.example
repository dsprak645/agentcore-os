# Example environment for the optional desktop runtime sidecar stack.
# Copy to `.env.agentcore-runtime` and replace placeholder values before use.

AGENTCORE_RUNTIME_PROFILE=desktop_dify
AGENTCORE_RUNTIME_APP_URL=http://127.0.0.1:3000
AGENTCORE_RUNTIME_URL=http://127.0.0.1:18080
AGENTCORE_DIFY_BASE_URL=http://127.0.0.1:18081
AGENTCORE_COMPOSE_PROJECT=agentcore_runtime
OPENCLAW_QUEUE_SECRET=replace-with-a-long-random-secret
